# REDIS (VM .190)
REDIS_PASSWORD=

# MINIO (VM .190)
MINIO_ENDPOINT=http://192.168.1.190:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ECAPA-TDNN semantic voice deduplication threshold (cosine similarity)
# 0.72 = same speaker with high confidence, 0.65 = permissive
ECAPA_THRESHOLD=0.72

# TeaCache intra-inference activation caching
# WARNING: experimental — enable only after baseline validation
TEACACHE_ENABLE=false
TEACACHE_THRESHOLD=0.015

# Optional cache tuning
# MEM_CACHE_MAX_AUDIO=10000
# MEM_CACHE_MAX_PROMPT=5000
# CACHE_AUDIO_TTL=604800
# CACHE_PROMPT_TTL=2592000
# CACHE_VECTOR_TTL=2592000
# CACHE_BUCKET=omnivoice-cache
